{
  "name": "web-dashboard",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3100",
    "build": "next build && cp -r public .next/standalone/apps/web && cp -r .next/static .next/standalone/apps/web/.next/",
    "lab": "cd .next/standalone/apps/web && dotenv -e ../../../../.env -v PORT=3100 -- node server.js",
    "start": "next start",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@repo/api-client": "workspace:*",
    "@repo/tsdb": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.97.0",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.7.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.17.0",
    "postcss": "^8.5.9",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@repo/ui": "workspace:*",
    "@types/node": "^24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.2.0",
    "server-only": "^0.0.1",
    "typescript": "6.0.2"
  }
}
