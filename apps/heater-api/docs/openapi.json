{
  "openapi": "3.1.0",
  "info": {
    "title": "Heater API (LT Capstone)",
    "description": "API Server that controls the Heater via GPIO with PID Logic.",
    "version": "0.1.0"
  },
  "paths": {
    "/channels": {
      "get": {
        "tags": [
          "Channels"
        ],
        "summary": "List Channels",
        "description": "List all configured channels from config.yaml.\n\nReturns information about all channels including their configuration\nand current runtime status (whether PID is active).",
        "operationId": "listChannels",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChannelListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/channels/status/all": {
      "get": {
        "tags": [
          "Channels"
        ],
        "summary": "Get All Channels Status",
        "description": "Get comprehensive status for all enabled channels at once.\n\nReturns detailed channel status including heater output state, PID controller\nstate, temperature readings, and error statistics for each enabled channel.",
        "operationId": "getAllChannelsStatus",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AllChannelsStatus"
                }
              }
            }
          }
        }
      }
    },
    "/channels/{channel_id}": {
      "get": {
        "tags": [
          "Channels"
        ],
        "summary": "Get Channel Info",
        "description": "Get information about a specific channel.\n\nReturns configuration and runtime status for the specified channel.",
        "operationId": "getChannelInfo",
        "parameters": [
          {
            "name": "channel_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Channel Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChannelInfo"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/channels/{channel_id}/status": {
      "get": {
        "tags": [
          "Channels"
        ],
        "summary": "Get Channel Status",
        "description": "Get comprehensive real-time status for a specific channel.\n\nReturns:\n- channel_id, channel_name: Channel identity\n- current_temp: Latest temperature reading in \u00b0C\n- heater: Real-time heater output (power fraction, measured watts, type, metadata)\n- pid: PID controller state (active, target, parameters, variables, timing, errors)",
        "operationId": "getChannelStatus",
        "parameters": [
          {
            "name": "channel_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Channel Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChannelStatusOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/config/{channel_id}/target-temp": {
      "get": {
        "tags": [
          "Config"
        ],
        "summary": "Get Target Temp",
        "description": "Get the current target temperature for a specific channel.",
        "operationId": "getTargetTemp",
        "parameters": [
          {
            "name": "channel_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Channel Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TargetTemp"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Config"
        ],
        "summary": "Set Target Temp",
        "description": "Set a new target temperature for a specific channel.",
        "operationId": "setTargetTemp",
        "parameters": [
          {
            "name": "channel_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Channel Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TargetTemp"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/config/{channel_id}/pid-parameters": {
      "get": {
        "tags": [
          "Config"
        ],
        "summary": "Get Pid Parameters",
        "description": "Get the current PID parameters for a specific channel.",
        "operationId": "getPidParameters",
        "parameters": [
          {
            "name": "channel_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Channel Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Parameters"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Config"
        ],
        "summary": "Set Pid Parameters",
        "description": "Update PID parameters for a specific channel.",
        "operationId": "setPidParameters",
        "parameters": [
          {
            "name": "channel_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Channel Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Parameters"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Parameters"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/config/{channel_id}/all": {
      "get": {
        "tags": [
          "Config"
        ],
        "summary": "Get All Config",
        "description": "Get all configuration (target temperature and PID parameters) for a specific channel.",
        "operationId": "getAllConfig",
        "parameters": [
          {
            "name": "channel_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Channel Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigAll"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/pid/{channel_id}/start": {
      "post": {
        "tags": [
          "PID"
        ],
        "summary": "Start Pid",
        "description": "Start the PID controller for a specific channel.",
        "operationId": "startPID",
        "parameters": [
          {
            "name": "channel_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Channel Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "title": "Response Startpid"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/pid/{channel_id}/stop": {
      "post": {
        "tags": [
          "PID"
        ],
        "summary": "Stop Pid",
        "description": "Stop the PID controller for a specific channel.",
        "operationId": "stopPID",
        "parameters": [
          {
            "name": "channel_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Channel Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "title": "Response Stoppid"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/pid/{channel_id}/manual-power": {
      "post": {
        "tags": [
          "PID"
        ],
        "summary": "Set Manual Power",
        "description": "Manually set heater power for a specific channel.\n\nStops the PID controller if it is currently running.\nPower is a normalized value between 0.0 and 1.0.",
        "operationId": "setManualPower",
        "parameters": [
          {
            "name": "channel_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Channel Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ManualPower"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "title": "Response Setmanualpower"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AllChannelsStatus": {
        "properties": {
          "channels": {
            "items": {
              "$ref": "#/components/schemas/ChannelStatusOut"
            },
            "type": "array",
            "title": "Channels"
          }
        },
        "type": "object",
        "required": [
          "channels"
        ],
        "title": "AllChannelsStatus",
        "description": "Status of all channels at once."
      },
      "ChannelInfo": {
        "properties": {
          "channelId": {
            "type": "integer",
            "title": "Channelid"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "thermoChannel": {
            "type": "integer",
            "title": "Thermochannel"
          },
          "heaterType": {
            "type": "string",
            "title": "Heatertype",
            "description": "Heater type: gpio, psu, or mock"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled"
          },
          "maxPowerWatts": {
            "type": "number",
            "title": "Maxpowerwatts",
            "description": "Maximum heater power in watts"
          },
          "isActive": {
            "type": "boolean",
            "title": "Isactive",
            "description": "Whether PID controller is currently active",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "channelId",
          "name",
          "thermoChannel",
          "heaterType",
          "enabled",
          "maxPowerWatts"
        ],
        "title": "ChannelInfo",
        "description": "Channel information with runtime status."
      },
      "ChannelListResponse": {
        "properties": {
          "channels": {
            "items": {
              "$ref": "#/components/schemas/ChannelInfo"
            },
            "type": "array",
            "title": "Channels"
          }
        },
        "type": "object",
        "required": [
          "channels"
        ],
        "title": "ChannelListResponse",
        "description": "List of all configured channels."
      },
      "ChannelStatusOut": {
        "properties": {
          "channelId": {
            "type": "integer",
            "title": "Channelid",
            "description": "Unique channel identifier from configuration."
          },
          "channelName": {
            "type": "string",
            "title": "Channelname",
            "description": "Human-readable channel name."
          },
          "currentTemp": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Currenttemp",
            "description": "Latest temperature reading in \u00b0C from the associated Lakeshore thermometer channel. Null if no reading yet."
          },
          "heater": {
            "$ref": "#/components/schemas/HeaterStatus",
            "description": "Real-time heater output state including power level, measured watts, and type-specific metadata."
          },
          "pid": {
            "$ref": "#/components/schemas/PidStatus",
            "description": "PID controller state including target, parameters, internal variables, timing, and error statistics."
          }
        },
        "type": "object",
        "required": [
          "channelId",
          "channelName",
          "heater",
          "pid"
        ],
        "title": "ChannelStatusOut",
        "description": "Comprehensive real-time status for a single heater channel.\n\nCombines channel identity, the current temperature reading,\nheater output state, and PID controller state into one response."
      },
      "ConfigAll": {
        "properties": {
          "targetTemp": {
            "type": "number",
            "title": "Targettemp"
          },
          "pidParameters": {
            "$ref": "#/components/schemas/Parameters"
          }
        },
        "type": "object",
        "required": [
          "targetTemp",
          "pidParameters"
        ],
        "title": "ConfigAll",
        "description": "Schema for all configuration data.\n\nContains target temperature and PID parameters."
      },
      "ErrorStats": {
        "properties": {
          "errorsLast1M": {
            "type": "integer",
            "title": "Errorslast1M"
          },
          "errorsLast10M": {
            "type": "integer",
            "title": "Errorslast10M"
          },
          "errorsSinceStart": {
            "type": "integer",
            "title": "Errorssincestart"
          },
          "lastErrorMessage": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Lasterrormessage"
          }
        },
        "type": "object",
        "required": [
          "errorsLast1M",
          "errorsLast10M",
          "errorsSinceStart",
          "lastErrorMessage"
        ],
        "title": "ErrorStats",
        "description": "Schema for error statistics.\n\nTracks API call errors over different time periods."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HeaterStatus": {
        "properties": {
          "power": {
            "type": "number",
            "title": "Power",
            "description": "Requested heater output level as a fraction (0.0 to 1.0). Reflects the value set by PID or manual control."
          },
          "powerWatts": {
            "type": "number",
            "title": "Powerwatts",
            "description": "Actual heater power in watts. For PSU heaters this is measured via voltage \u00d7 current; for GPIO/Mock heaters it is calculated from the configured max power."
          },
          "heaterType": {
            "type": "string",
            "title": "Heatertype",
            "description": "Heater type identifier: 'gpio', 'psu', or 'mock'."
          },
          "heaterMetadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Heatermetadata",
            "description": "Heater-type-specific metadata. PSU: measured_voltage, measured_current, max_voltage, max_current, max_wattage. GPIO/Mock: empty.",
            "default": {}
          }
        },
        "type": "object",
        "required": [
          "power",
          "powerWatts",
          "heaterType"
        ],
        "title": "HeaterStatus",
        "description": "Real-time heater output state.\n\nReports the current power level and heater-type-specific metadata."
      },
      "ManualPower": {
        "properties": {
          "power": {
            "type": "number",
            "title": "Power"
          }
        },
        "type": "object",
        "required": [
          "power"
        ],
        "title": "ManualPower",
        "description": "Schema for manual power control.\n\nPower is a normalized value between 0.0 and 1.0."
      },
      "Parameters": {
        "properties": {
          "kp": {
            "type": "number",
            "title": "Kp",
            "default": 1.0
          },
          "ki": {
            "type": "number",
            "title": "Ki",
            "default": 0.0
          },
          "kd": {
            "type": "number",
            "title": "Kd",
            "default": 0.0
          }
        },
        "type": "object",
        "title": "Parameters",
        "description": "Schema for temperature parameters.\n\nUsed by GET and PUT /temp/parameters endpoints\nto retrieve or update temperature parameters."
      },
      "PidStatus": {
        "properties": {
          "isActive": {
            "type": "boolean",
            "title": "Isactive",
            "description": "Whether the PID control loop is currently running."
          },
          "target": {
            "type": "number",
            "title": "Target",
            "description": "Target temperature in \u00b0C that the PID is tracking."
          },
          "startedAt": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Startedat",
            "description": "UTC timestamp when the PID loop was started. Null if PID has never been started or was stopped."
          },
          "runningForSeconds": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Runningforseconds",
            "description": "Elapsed seconds since the PID loop was started. Null when PID is not active."
          },
          "parameters": {
            "$ref": "#/components/schemas/Parameters",
            "description": "Current PID tuning coefficients (Kp, Ki, Kd)."
          },
          "variables": {
            "$ref": "#/components/schemas/PidVariables",
            "description": "Internal PID state: integral accumulator, last error, and last temperature measurement."
          },
          "errorStats": {
            "$ref": "#/components/schemas/ErrorStats",
            "description": "Error counters for thermometer API read failures over 1 min, 10 min, and since PID start."
          }
        },
        "type": "object",
        "required": [
          "isActive",
          "target",
          "parameters",
          "variables",
          "errorStats"
        ],
        "title": "PidStatus",
        "description": "PID controller state.\n\nContains whether the PID loop is running, its target, tuning parameters,\ninternal variables, timing information, and error statistics."
      },
      "PidVariables": {
        "properties": {
          "integral": {
            "type": "number",
            "title": "Integral"
          },
          "lastError": {
            "type": "number",
            "title": "Lasterror"
          },
          "lastMeasurement": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Lastmeasurement"
          }
        },
        "type": "object",
        "required": [
          "integral",
          "lastError",
          "lastMeasurement"
        ],
        "title": "PidVariables",
        "description": "Schema for PID internal variables.\n\nContains the interval variables used in PID calculations."
      },
      "TargetTemp": {
        "properties": {
          "target": {
            "type": "number",
            "title": "Target"
          }
        },
        "type": "object",
        "required": [
          "target"
        ],
        "title": "TargetTemp",
        "description": "Schema for target temperature.\n\nUsed by GET and PUT /temp/target-temp endpoints\nto retrieve or update target temperature."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}