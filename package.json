{
  "name": "low-temperature-control",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build --continue=dependencies-successful",
    "dev": "turbo run dev",
    "lint": "turbo run lint --continue && prettier --check *.js",
    "format": "turbo run format --continue && prettier --write *.js",
    "check-types": "turbo run check-types",
    "codegen": "turbo run codegen",
    "lab": "turbo run lab"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/node": "^24.12.2",
    "prettier": "^3.8.2",
    "turbo": "^2.9.6",
    "typescript": "6.0.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^24.11"
  },
  "pnpm": {
    "overrides": {
      "exact-mirror": "^0.2.7"
    }
  }
}
