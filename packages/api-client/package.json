{
  "name": "@repo/api-client",
  "private": true,
  "type": "module",
  "main": "src/typescript/index.ts",
  "scripts": {
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf src/python && rm -f src/typescript/*.d.ts",
    "codegen:ogc": "openapi-generator-cli generate",
    "codegen:ts": "sh ./ts-codegen.sh && pnpm format",
    "codegen:no-clean": "pnpm codegen:ogc && pnpm codegen:ts",
    "codegen": "pnpm clean && pnpm codegen:no-clean"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@repo/config": "workspace:*",
    "eslint": "^10.1.0",
    "openapi-typescript": "^7.13.0"
  }
}
